# FTP source
FTP_HOST=ftp.datasus.gov.br
FTP_PATHS=/dissemin/publicos/SIHSUS/200801_/Dados,/dissemin/publicos/SIASUS/200801_/Dados
FTP_CONN_POOL=2
PAUSE_DOWNLOADS=true

# Database
DATABASE_URL=postgres://datasus:datasus@db:5432/datasus

# Storage
STORAGE_ROOT=/data

# Scheduling
CRON_SCHEDULE=0 2 * * *
FTP_SCAN_TIMEOUT=30m

# Worker concurrency
DOWNLOAD_WORKERS=5
CSV_WORKERS=3
PARQUET_WORKERS=3

# Retry behaviour
RETRY_BASE_DELAY=30s
RETRY_MAX_DELAY=1h
STUCK_JOB_TIMEOUT=30m

# Observability
LOG_LEVEL=info

# API
API_PORT=8080

